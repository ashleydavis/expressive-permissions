{
    "name": "expressive-permissions",
    "version": "0.0.1",
    "type": "module",
    "license": "MIT",
    "scripts": {
        "bundle:pre": "bun build src/pre-hook.ts --outfile plugin/dist/pre-hook.js --target node",
        "bundle:post": "bun build src/post-hook.ts --outfile plugin/dist/post-hook.js --target node",
        "bundle:mcp": "bun build src/mcp-server.ts --outfile plugin/dist/mcp-server.js --target node",
        "bundle": "bun run bundle:pre && bun run bundle:post && bun run bundle:mcp",
        "b": "bun run bundle",
        "repl": "bun run src/repl.ts",
        "r": "bun run repl",
        "compile": "tsc --noEmit",
        "c": "bun run compile",
        "test": "jest --passWithNoTests",
        "t": "bun run test",
        "test:watch": "jest --watch",
        "tw": "bun run test:watch",
        "smoke": "bash scripts/smoke-tests.sh",
        "smoke:repl": "bash scripts/repl-smoke-tests.sh",
        "gen:examples": "bun run scripts/gen-examples.ts",
        "validate": "claude plugin validate ./plugin && claude plugin validate .",
        "test:all": "bun run validate && bun run test && bash scripts/smoke-tests-bash-parser.sh && bash scripts/smoke-tests-bash-examples.sh && bash scripts/hook-smoke-tests.sh && bash scripts/smoke-tests.sh && bash scripts/repl-smoke-tests.sh",
        "ta": "bun run test:all",
        "dev": "claude --plugin-dir ./plugin",
        "d": "bun run dev"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "picomatch": "^4.0.2",
        "shell-quote": "^1.8.1",
        "yaml": "^2.7.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/shell-quote": "^1.7.5",
        "jest": "^29.7.0",
        "ts-jest": "^29.3.2",
        "typescript": "^5.8.3"
    }
}
